{
  "name": "webhachimi",
  "version": "0.1.0",
  "description": "TypeScript/Pixi browser game editor, 2D runtime, static export pipeline, and verification workbench.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tanmologist/WebHachimi.git"
  },
  "bugs": {
    "url": "https://github.com/Tanmologist/WebHachimi/issues"
  },
  "homepage": "https://github.com/Tanmologist/WebHachimi#readme",
  "engines": {
    "node": ">=24.12.0 <25",
    "npm": ">=11.6.2 <12"
  },
  "scripts": {
    "serve": "node server.js",
    "serve:legacy": "node -e \"process.env.WEBHACHIMI_ENTRY_PATH='/index.html'; require('./server.js')\"",
    "serve:preview": "node -e \"process.env.WEBHACHIMI_NO_BROWSER='1'; process.env.WEBHACHIMI_PORT='5578'; require('./server.js')\"",
    "dev": "npm run dev:editor",
    "dev:editor": "vite --host 127.0.0.1 --open /apps/webhachimi/editor.html",
    "dev:v2": "npm run dev:editor",
    "dev:game": "vite --host 127.0.0.1 --open /games/hachimi-nanbei-lvdong/index.html",
    "dev:game:editor": "vite --host 127.0.0.1 --open /games/hachimi-nanbei-lvdong/editor.html",
    "dev:player": "npm run dev:game",
    "build": "vite build",
    "build:editor": "vite build --mode editor",
    "build:game": "vite build --mode game",
    "export:game": "node scripts/export-static-game.cjs hachimi-nanbei-lvdong",
    "smoke:export-game": "npm run build:game && node scripts/export-static-game.cjs hachimi-nanbei-lvdong --out exports/smoke-hachimi-nanbei-lvdong --skip-build && tsx src/testing/staticGameExportSmoke.ts exports/smoke-hachimi-nanbei-lvdong",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean:logs": "node -e \"const fs=require('node:fs'); for (const name of fs.readdirSync('.')) if (name.endsWith('.log')) fs.rmSync(name,{force:true});\"",
    "smoke": "npm run smoke:persistence && npm run smoke:persistence-api && npm run smoke:samples && npm run smoke:folder-move && npm run smoke:task-workflow && npm run smoke:super-brush-evidence && npm run smoke:canvas-guide && npm run smoke:task-panel && npm run smoke:autonomy-summary && npm run smoke:viewport && npm run smoke:keyboard && npm run smoke:context-menu && npm run smoke:entity-properties && npm run smoke:resource-import && npm run smoke:resource-animation && npm run smoke:world-manager && npm run smoke:world-speed && npm run smoke:canvas-transform && npm run smoke:collision-geometry && npm run smoke:presentation-label && npm run smoke:floating-panels && npm run smoke:workspace-presets && npm run smoke:runtime-visibility && npm run smoke:performance && npm run smoke:combat-action-protocol && npm run smoke:workshops && npm run smoke:transform && npm run smoke:sweep && npm run smoke:autonomy",
    "verify": "npm run typecheck && npm run build && npm run smoke",
    "smoke:persistence": "tsx src/testing/persistenceControllerSmoke.ts",
    "smoke:persistence-api": "tsx src/testing/persistenceApiSmoke.ts",
    "smoke:samples": "tsx src/testing/sampleProjectSmoke.ts",
    "smoke:folder-move": "tsx src/testing/folderMoveTransactionSmoke.ts",
    "smoke:task-workflow": "tsx src/testing/taskWorkflowControllerSmoke.ts",
    "smoke:super-brush-evidence": "tsx src/testing/superBrushEvidenceSmoke.ts",
    "smoke:canvas-guide": "tsx src/testing/canvasGuidePanelSmoke.ts",
    "smoke:task-panel": "tsx src/testing/taskPanelViewsSmoke.ts",
    "smoke:autonomy-summary": "tsx src/testing/autonomySummaryModelsSmoke.ts",
    "smoke:viewport": "tsx src/testing/viewportMathSmoke.ts",
    "smoke:keyboard": "tsx src/testing/keyboardControllerSmoke.ts",
    "smoke:context-menu": "tsx src/testing/contextMenuActionsSmoke.ts",
    "smoke:entity-properties": "tsx src/testing/entityPropertyTransactionsSmoke.ts",
    "smoke:resource-import": "tsx src/testing/resourceImportSmoke.ts",
    "smoke:resource-animation": "tsx src/testing/resourceAnimationSmoke.ts",
    "smoke:world-manager": "tsx src/testing/worldManagerViewsSmoke.ts",
    "smoke:world-speed": "tsx src/testing/worldSpeedSmoke.ts",
    "smoke:canvas-transform": "tsx src/testing/canvasTransformSmoke.ts",
    "smoke:collision-geometry": "tsx src/testing/collisionGeometrySmoke.ts",
    "smoke:presentation-label": "tsx src/testing/presentationLabelSmoke.ts",
    "smoke:floating-panels": "tsx src/testing/floatingPanelLayoutSmoke.ts",
    "smoke:workspace-presets": "tsx src/testing/workspacePresetSmoke.ts",
    "smoke:runtime-visibility": "tsx src/testing/runtimeVisibilitySmoke.ts",
    "smoke:performance": "tsx src/testing/performanceSmoke.ts",
    "smoke:combat-action-protocol": "tsx src/testing/combatActionProtocolSmoke.ts",
    "smoke:workshops": "tsx src/testing/gameplayWorkshopSmoke.ts",
    "smoke:transform": "tsx src/testing/transformTransactionSmoke.ts",
    "smoke:selection": "tsx src/testing/selectionSmoke.ts",
    "smoke:sweep": "tsx src/testing/smokeSweep.ts",
    "smoke:autonomy": "tsx src/testing/autonomySmoke.ts"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "pixi.js": "^8.18.1"
  }
}
